# ─── Airtable (event creation) ───────────────────────────────────────────────
# Create a Personal Access Token at https://airtable.com/create/tokens
# Scopes needed: data.records:write  |  Base: appNhBL4aHe7HTv7t
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=appNhBL4aHe7HTv7t

# Optional blockchain booking configuration.
# Leave these blank for demo/mock ticket behavior.
EMS_RPC_URL=
EMS_EVENT_REGISTRY=
EMS_TICKET_CREDENTIAL=
EMS_ORGANIZER_KEY=

# Optional Groq chatbot configuration.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Required for payments. Get keys at https://dashboard.stripe.com/apikeys
# Use sk_test_... / pk_test_... for development (sandbox).
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Base URL of the app (used for Stripe redirect fallback only).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── SMTP email (ticket confirmation) ────────────────────────────────────────
# Any SMTP provider works: Gmail, Resend, Mailgun, Postmark, etc.
#
# Gmail example (use an App Password, not your account password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=your-app-password
#
# Resend example (relay mode):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_USER=resend
#   SMTP_PASSWORD=re_...
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=ZITIKS <no-reply@example.com>

# ─── Twilio SMS (optional ticket SMS) ────────────────────────────────────────
# Leave blank to disable SMS. Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
